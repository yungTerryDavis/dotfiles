// -*- mode: jsonc -*-
{
    // https://github.com/Alexays/Waybar/wiki/Configuration
    "layer": "bottom",
    "position": "top",
    "spacing": 4,
    "font": "JetBrainsMono Nerd Font 14",
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "mpd",
        "pulseaudio",
        "bluetooth",
        "network",
        // "keyboard-state",
        "hyprland/language",
        "battery",
        "tray"
    ],
    // Modules configuration
    "hyprland/workspaces": {
        "active-only": false,
        "on-click": "hyprctl dispatch workspace {id}"
    },
    "hyprland/window": {},

    "clock": {
        "format": "{:%H:%M | %a, %d %b (%V)}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "mpd": {
        "server": "/home/ngumbk/.local/share/mpd/socket",
        "format": "{stateIcon}({elapsedTime:%M:%S}/{totalTime:%M:%S}) ’Ćü",
        "format-disconnected": "Disconnected ’Ćü",
        "format-stopped": "Stopped ’Ćü",
        "tooltip-format": "Vol: {volume}%\nTrack: {artist} - {title}\nAlbum: {album}\nPos: (({songPosition}/{queueLength}))",
        "unknown-tag": "N/A",
        "interval": 5,
        "on-click": "rmpc togglepause",
        "on-click-right": "rmpc next",
        "on-scroll-up": "rmpc volume +5",
        "on-scroll-down": "rmpc volume -5",
        "state-icons": {
            "paused": "’üī",
            "playing": "’üŗ"
        }
    },
    "pulseaudio": {  // icons
        "scroll-step": 5,
        "format": "{icon}   {volume}%",
        "tooltip-format": "Vol: {volume}%\nMicro: {format_source}",
        "format-muted": "¾░Ø¤ Mute all chat ŌłÜ",
        "format-bluetooth": "{icon} ’Ŗö  {volume}%",
        "format-bluetooth-muted": "¾░Ø¤ ’Ŗö Mute all chat ŌłÜ",
        "format-source": "’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "default": ["’Ć¦", "’Ć©"]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format-no-controller": "BT down",  // Service down
        "format-disabled": "BT disabled",
        "format-off": " BT Off",  //
        "format-on": "BT On",  // Service up, disconnected
        "format-connected": "BT Conn"  // Service up, connected
    },
    "network": {  // icons
        "format-wifi": "{icon}",
        "format-disconnected": "Disconnected ŌÜĀ",  // add icon for disconnected
        "format-alt": "{essid} ({signalStrength}%) {ifname}: {ipaddr}/{cidr}",
        "format-icons": ["’ć½"]  // add icons
    },
    "keyboard-state": {  // include user into group (check github)
        "capslock": true,
        "format": {
            "capslock": "{icon}"
        },
        "format-icons": {  // find Aa icons
            "locked": "’ĆŻ",
            "unlocked": "’é£"
        }
    },
    "hyprland/language": {  // fix icon
        "format": "Ņ╣ć {}",
        "format-en": "US",
        "format-ru": "RU"
    },
    "battery": {  // icons and css
        "states": {
            // 100-95 - make green
            // "good": 95,  // make white
            "warning": 30,  // make yellow
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% {icon} ’ā¦",  // find icons
        "format-plugged": "{capacity}% ’ć”",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },
    "tray": {
        "spacing": 10
    }
}
